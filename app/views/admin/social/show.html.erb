<div class="mt-16 px-6 lg:px-8">
  <div class="mx-auto max-w-2xl lg:max-w-4xl mb-8">
    <h1 class="text-pretty text-4xl font-medium tracking-tight text-gray-950 mb-6">Social media</h1>

    <div id="facebook_result"></div>

    <% unless @facebook_configured %>
      <div class="mb-6 rounded-md bg-yellow-50 border border-yellow-200 p-4 text-sm text-yellow-800">
        Facebook is not configured. Add <code class="font-mono bg-yellow-100 px-1 rounded">facebook.page_id</code> and <code class="font-mono bg-yellow-100 px-1 rounded">facebook.page_token</code> to Rails credentials to enable posting.
      </div>
    <% end %>

    <div class="rounded-lg border border-gray-200 bg-white shadow-sm"
         data-controller="social-composer"
         data-social-composer-site-url-value="<%= Admin::SocialController::SITE_BASE_URL %>"
         data-social-composer-strava-url-value="<%= Admin::SocialController::STRAVA_CLUB_URL %>">
      <%# Hidden template sources for JS loading %>
      <% if @upcoming_event %>
        <div id="template-pre-event" class="hidden"><%= @pre_event_message %></div>
      <% end %>
      <% if @recent_event %>
        <div id="template-post-event" class="hidden"><%= @post_event_message %></div>
      <% end %>

      <div class="border-b border-gray-200 px-6 py-4">
        <h2 class="text-xl font-medium text-gray-950">Compose message</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          <% if @upcoming_event %>
            <%= link_to admin_social_path(template: "pre_event"),
                  data: { action: "click->social-composer#loadTemplate", "social-composer-template-param": "pre-event" },
                  class: "rounded-md bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-200" do %>
              Load pre-event &mdash; WS10 <%= @upcoming_event.number %> (<%= @upcoming_event.date.strftime("%-d %b") %>)
            <% end %>
          <% end %>
          <% if @recent_event %>
            <% unless @recent_event.description.present? %>
              <span class="text-xs text-yellow-700 self-center">
                <%= link_to "Edit WS10 #{@recent_event.number}", edit_admin_event_path(@recent_event.number), class: "underline" %> to add a description before loading post-event template.
              </span>
            <% end %>
            <%= link_to admin_social_path(template: "post_event"),
                  data: { action: "click->social-composer#loadTemplate", "social-composer-template-param": "post-event" },
                  class: "rounded-md bg-gray-100 px-3 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-200" do %>
              Load post-event &mdash; WS10 <%= @recent_event.number %> (<%= @recent_event.date.strftime("%-d %b") %>)
            <% end %>
          <% end %>
          <% unless @upcoming_event || @recent_event %>
            <span class="text-sm text-gray-500">No events available to load templates for.</span>
          <% end %>
        </div>
      </div>

      <div class="px-6 py-4">
        <%= form_with url: admin_social_facebook_path, method: :post,
              data: { action: "turbo:submit-end->social-composer#handleSubmitEnd" } do |f| %>
          <%= f.text_area :message,
                value: @message,
                data: { "social-composer-target": "textarea" },
                rows: 8,
                placeholder: "Load a template above or type your message here…",
                class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary font-mono" %>

          <div class="mt-4 flex flex-wrap items-end gap-3 border-t border-gray-100 pt-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-500 uppercase tracking-wide">Schedule for Facebook</label>
              <%= f.datetime_local_field :scheduled_at,
                    value: @default_scheduled_at.strftime("%Y-%m-%dT%H:%M"),
                    class: "block rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" %>
            </div>

            <button type="submit"
                    data-social-composer-target="submitButton"
                    <%= "disabled" unless @facebook_configured %>
                    class="rounded-md px-4 py-2 text-sm font-medium text-white cursor-pointer <%= @facebook_configured ? "bg-blue-600 hover:bg-blue-700" : "bg-gray-400 cursor-not-allowed" %>">
              Schedule Facebook post
            </button>

            <button type="submit"
                    data-social-composer-target="submitButton"
                    data-action="click->social-composer#schedulePost"
                    <%= "disabled" unless @facebook_configured %>
                    class="rounded-md px-4 py-2 text-sm font-medium text-white cursor-pointer <%= @facebook_configured ? "bg-blue-600 hover:bg-blue-700" : "bg-gray-400 cursor-not-allowed" %>">
              Schedule &amp; copy for Strava
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
